{
  "info": {
    "name": "EmployeeManagementAPI",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "employeeId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "GET all employees",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST create employee success",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Doan Van F\",\n  \"department\": \"Engineering\",\n  \"salary\": 16000000\n}"
        },
        "url": "{{baseUrl}}/api/employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has id', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.collectionVariables.set('employeeId', json.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET employee by id success",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has id', function () {",
              "    pm.expect(pm.response.json()).to.have.property('id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET employee by id not found",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/employees/999999"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST create employee validation error",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"\",\n  \"department\": \"Engineering\",\n  \"salary\": -1\n}"
        },
        "url": "{{baseUrl}}/api/employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT update employee success",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Doan Van F Updated\",\n  \"department\": \"Marketing\",\n  \"salary\": 17000000\n}"
        },
        "url": "{{baseUrl}}/api/employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has id', function () {",
              "    pm.expect(pm.response.json()).to.have.property('id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT update employee not found",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Unknown\",\n  \"department\": \"Finance\",\n  \"salary\": 10000000\n}"
        },
        "url": "{{baseUrl}}/api/employees/999999"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE employee success",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 204', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE employee not found",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/employees/999999"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
